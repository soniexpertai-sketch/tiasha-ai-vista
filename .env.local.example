# Get a free API key at https://resend.com — for real deliverability, verify
# your sending domain there too (Domains → Add Domain → add the DNS records).
RESEND_API_KEY=

# Inbox that should receive lead form submissions.
LEAD_TO_EMAIL=info@yourdomain.com

# Optional — must be an address on a domain verified in Resend.
# Falls back to Resend's shared sandbox sender if unset (only reliably
# delivers to the email that owns the Resend account — fine for testing,
# not for production).
LEAD_FROM_EMAIL=Your Company <leads@yourdomain.com>
